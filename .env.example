# ============================================================
# FALCO DISTRESS ENGINE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# REQUIRED — Supabase (where bot leads land)
# Bots upsert directly to homeowner_requests via supabase_store.
# Notion was removed 2026-04-29 — these are the only required
# vars to run the pipeline.
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt_here

# ------------------------------------------------------------
# OPTIONAL — Enrichment APIs (unused in default pipeline)
# Stage 2/3 enrichment runs via Vercel cron at
# /api/cron/refresh-dialer (BatchData skip-trace + AVM backfill).
# Only needed locally if you set FALCO_ENABLE_LEGACY_STAGES=1
# to test the old enrichment paths.
# ------------------------------------------------------------
FALCO_BATCHDATA_API_KEY=your_batchdata_api_key_here
FALCO_ATTOM_API_KEY=your_attom_api_key_here

# ------------------------------------------------------------
# OPTIONAL — Geography
# Comma-separated base county names (no "County" suffix).
# Default: Davidson,Williamson,Rutherford,Wilson,Sumner
# ------------------------------------------------------------
# FALCO_ALLOWED_COUNTIES=Davidson,Williamson,Rutherford,Wilson,Sumner

# ------------------------------------------------------------
# OPTIONAL — Days-to-Sale (DTS) Window
# Default: 21 min, 90 max
# ------------------------------------------------------------
# FALCO_DTS_MIN=21
# FALCO_DTS_MAX=90

# ------------------------------------------------------------
# OPTIONAL — Re-enable legacy Notion-coupled stages
# (enrichment + grading + packaging) for local dev.
# Default off; production pipeline doesn't use these.
# ------------------------------------------------------------
# FALCO_ENABLE_LEGACY_STAGES=1
