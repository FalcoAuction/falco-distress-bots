# ============================================================
# FALCO DISTRESS ENGINE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control (already in .gitignore).
# ============================================================

# ------------------------------------------------------------
# REQUIRED — Supabase (where bot leads land)
# Bots write to homeowner_requests + homeowner_requests_staging
# via the supabase-py service-role client. Same values used by
# falco-site/.env.local.
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt_here

# ------------------------------------------------------------
# REQUIRED for the autonomous decision engine
# Used by decision_engine_bot for gray-area lead grading.
# Falls back to rule-engine-only mode if missing (no crash).
# Get key at: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=sk-proj-your_openai_key_here

# ------------------------------------------------------------
# OPTIONAL — LLM provider override
# Default model is gpt-5-mini. Set to gpt-5-nano for cheaper
# (~70% cost reduction) or gpt-5 for higher reasoning.
# ------------------------------------------------------------
# FALCO_LLM_MODEL=gpt-5-mini

# ------------------------------------------------------------
# OPTIONAL — Legacy enrichment APIs (unused in default pipeline)
# Stage 2/3 enrichment via Vercel cron at /api/cron/refresh-dialer.
# Only set if testing legacy paths locally with
# FALCO_ENABLE_LEGACY_STAGES=1.
# ------------------------------------------------------------
FALCO_BATCHDATA_API_KEY=your_batchdata_api_key_here
FALCO_ATTOM_API_KEY=your_attom_api_key_here

# ------------------------------------------------------------
# OPTIONAL — Geography
# Comma-separated TN county names (no "County" suffix).
# Default: Davidson,Williamson,Rutherford,Wilson,Sumner
# ------------------------------------------------------------
# FALCO_ALLOWED_COUNTIES=Davidson,Williamson,Rutherford,Wilson,Sumner

# ------------------------------------------------------------
# OPTIONAL — Days-to-Sale (DTS) Window
# Default: 21 min, 90 max
# ------------------------------------------------------------
# FALCO_DTS_MIN=21
# FALCO_DTS_MAX=90

# ------------------------------------------------------------
# OPTIONAL — Re-enable legacy Notion-coupled stages
# (enrichment + grading + packaging) for local dev.
# Default off; production pipeline doesn't use these.
# ------------------------------------------------------------
# FALCO_ENABLE_LEGACY_STAGES=1
