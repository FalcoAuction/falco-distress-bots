# ============================================================
# FALCO DISTRESS ENGINE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# REQUIRED — Notion Integration
# ------------------------------------------------------------
NOTION_API_KEY=your_notion_integration_secret_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ------------------------------------------------------------
# REQUIRED (for ATTOM enrichment) — ATTOM API
# If not set, ATTOM enrichment is silently skipped (safe no-op).
# ------------------------------------------------------------
FALCO_ATTOM_API_KEY=your_attom_api_key_here

# ------------------------------------------------------------
# OPTIONAL — Geography
# Comma-separated base county names (no "County" suffix).
# Default: Davidson,Williamson,Rutherford,Sumner,Wilson,Maury,Montgomery,Knox,Hamilton
# ------------------------------------------------------------
# FALCO_ALLOWED_COUNTIES=Davidson,Williamson,Rutherford,Sumner,Wilson,Maury,Montgomery,Knox,Hamilton

# ------------------------------------------------------------
# OPTIONAL — Days-to-Sale (DTS) Window
# Default: 21 min, 90 max
# ------------------------------------------------------------
# FALCO_DTS_MIN=21
# FALCO_DTS_MAX=90

# ------------------------------------------------------------
# OPTIONAL — Enrichment Controls
# ------------------------------------------------------------
# FALCO_MAX_ENRICH_PER_RUN=10
# FALCO_ENABLE_BATCHDATA_FALLBACK=0
# FALCO_BATCHDATA_API_KEY=your_batchdata_api_key_here
# FALCO_MAX_BATCHDATA_ENRICH_PER_RUN=6
# FALCO_SKIP_TRACE_PROVIDER=null
# FALCO_SRI_API_KEY=public_or_private_sri_api_key_here
# FALCO_ENRICH_NO_RESULT_COOLDOWN_HOURS=72
# FALCO_SKIP_INSTITUTIONAL_ENRICH=1
# FALCO_MARK_INSTITUTIONAL_SKIP=1
# FALCO_ENRICH_DEBUG=0

# ------------------------------------------------------------
# OPTIONAL — Outreach Agent (review-first cold outreach)
# Gmail sending only activates when both are set and --send is used.
# ------------------------------------------------------------
# FALCO_GMAIL_USER=falcoauction@gmail.com
# FALCO_GMAIL_APP_PASSWORD=your_gmail_app_password_here

# ------------------------------------------------------------
# OPTIONAL — Notion Write Kill Switch
# Default is SAFE (writes disabled). Set to 1 to allow
# create/update calls to reach Notion.
# ------------------------------------------------------------
FALCO_NOTION_WRITE=0

# ------------------------------------------------------------
# OPTIONAL — Notion Schema
# Set to 0 to disable auto-adding missing schema properties.
# ------------------------------------------------------------
# FALCO_NOTION_AUTO_SCHEMA=1

# ------------------------------------------------------------
# OPTIONAL — Packaging
# ------------------------------------------------------------
# FALCO_MAX_PACKETS_PER_RUN=10

# ------------------------------------------------------------
# OPTIONAL — Automation
# Set FALCO_AUTO_PUBLISH_VAULT=1 to sync packets/listings into
# falco-site and import them into Supabase after packaging.
# ------------------------------------------------------------
# FALCO_AUTO_PUBLISH_VAULT=0
# FALCO_SITE_REPO=C:\code\falco-site

# ------------------------------------------------------------
# OPTIONAL — Google Drive Upload (if used)
# ------------------------------------------------------------
# GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=base64_encoded_service_account_json
